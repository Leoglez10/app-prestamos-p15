{
	"$schema": "https://schema.tauri.app/config/2",
	"productName": "App Prestamos P15",
	"version": "0.1.1",
	"identifier": "com.p15.prestamos",
	"build": {
		"beforeDevCommand": "npm run dev",
		"devUrl": "http://localhost:1770",
		"beforeBuildCommand": "npm run build",
		"frontendDist": "../dist"
	},
	"app": {
		"windows": [
			{
				"title": "App Prestamos P15",
				"width": 1280,
				"height": 840,
				"minWidth": 1024,
				"minHeight": 680,
				"resizable": true
			}
		],
		"security": {
			"csp": null
		}
	},
	"bundle": {
		"active": true,
		"targets": "all",
		"icon": [
			"icons/32x32.png",
			"icons/128x128.png",
			"icons/128x128@2x.png",
			"icons/icon.icns",
			"icons/icon.ico"
		]
	}
}
